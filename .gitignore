__pycache__/
*.py[cod]
.lake/
lake-manifest.json

# Autoresearch MVP-0.1.8 (Phase A) — sibling lockfiles for the
# append-only JSONL ledgers (created on first concurrent write
# by attempts_append.py / nogolog_append.py / survivor_append.py;
# never carry canonical content).
outputs/*.jsonl.lock

# Autoresearch MVP-0.2 (Phase B) — coordinator state.  Carries
# in-progress lease + dedup state; reconstructible from
# outputs/attempts.jsonl on coordinator restart.
coordinator/state.db
coordinator/state.db-journal
coordinator/state.db-wal
coordinator/state.db-shm

# Local LeanDojo-v2 integration and generated artifacts.
tools/LeanDojo-v2/
tools/lean_dojo_raid/
tools/lean_dojo_cache/
tools/lean_dojo_outputs/
tools/lean_dojo_tmp/
