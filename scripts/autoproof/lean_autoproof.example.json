{
  "project_root": "/path/to/lean/project",
  "target_file": "/path/to/lean/project/MyProject/RemainingProof.lean",
  "theorem_names": [
    "MyProject.RemainingProof.main_theorem"
  ],
  "max_iters": 60,
  "lean_cmd": ["lake", "env", "lean"],
  "lake_build_cmd": ["lake", "build"],
  "check_whole_project": true,
  "forbid_axiom_keywords": true,
  "proposer": {
    "mode": "command",
    "cmd": "my_llm_cli --prompt {prompt_path} --output {output_path}",
    "read": "output_file",
    "timeout_sec": 300
  }
}
